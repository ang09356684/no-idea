# ── 這些全部留空也能啟動 app ──
# 未填時：Google 登入停用，口袋名單 / 最愛改存瀏覽器 localStorage（僅本機、不跨裝置）。
# 填了才會啟用 Google 登入 + Cloud Firestore 雲端同步（判斷依據：有沒有 PROJECT_ID）。

# Firebase Web 設定
# 這些是「公開值」：會被 inline 進 client bundle，外露是正常的。
# 安全性靠 Firebase Authentication + Firestore Security Rules，不是靠藏這些值。
# 取得方式：Firebase console → 專案設定 → 你的 Web App → SDK setup and configuration。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# 本機用 Firebase Emulator 開發時設為 true（完全不連雲端、可離線）。
# 搭配 PROJECT_ID 用 demo- 開頭的 id（例如 demo-where-to-date）即可純本機測試。
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=
